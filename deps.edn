{:paths ["src" "resources"]
 :deps  {org.clojure/data.json       {:mvn/version "2.5.0"}
         hiccup/hiccup               {:mvn/version "2.0.0-RC3"}
         org.clojure/tools.logging   {:mvn/version "1.3.0"}
         org.slf4j/slf4j-simple      {:mvn/version "2.0.16"}}
 :aliases
 {:run  {:main-opts ["-m" "explorer.service"]}
  :dev  {:jvm-opts  ["-Dclojure.server.dev={:port 5556 :accept clojure.core.server/io-prepl}"]
         :main-opts ["-e" "(do (println \"dev prepl on :5556\") @(promise))"]}}}
